# Copy to .env (or .env.local) and fill in real values (never commit .env).

# Backend URL (no trailing slash).
# Local dev: leave EMPTY to use Vite proxy (same tab as http://127.0.0.1:5173 → API on 4000).
# Or set http://127.0.0.1:4000 to talk to the API directly.
# Production: required — e.g. https://api.yoursite.com
VITE_BASE_URL=

# Google Maps JS key (map + Places in the browser). In Cloud Console enable:
# - Maps JavaScript API
# - Places API (New)   ← required for address search; without it you get ApiTargetBlockedMapError
# Under API key restrictions, include those APIs in the allowed list (not only "Maps SDK").
# Referrer: http://127.0.0.1:5173/* and your production origins.
VITE_GOOGLE_MAPS_API=your_google_maps_browser_key

# Optional: Map ID for Advanced Markers (https://console.cloud.google.com/google/maps-apis/studio/maps).
# If unset, DEMO_MAP_ID is used for local testing per Google’s migration guide.
# VITE_GOOGLE_MAP_ID=
