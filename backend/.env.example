# Copy to .env and fill in real values (never commit .env).

# HTTP port for Express + Socket.IO (default 4000 if omitted)
PORT=4000

# Quick local run without installing MongoDB: use npm run dev:memory (sets this automatically).
# Or use Docker/real MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/uberdb
# USE_IN_MEMORY_MONGO=true

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_string

# If the client's browser key uses "HTTP referrers" restriction, it cannot be used from Node.
# Use a second key here for server-side APIs only (restriction: None, or IP addresses of your API host).
GOOGLE_MAPS_SERVER_API=your_server_unrestricted_or_ip_restricted_key

# Optional fallback: same as server key if it has no referrer restriction
GOOGLE_MAPS_API=your_google_maps_server_key

# Optional: Socket.IO CORS (comma-separated). Defaults include localhost + centralgo.mercalan.com.co; *.vercel.app and *.onrender.com are always allowed.
# CLIENT_ORIGINS=https://centralgo.mercalan.com.co,https://your-preview.vercel.app
